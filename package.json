{
  "name": "@glasshome/ha-types",
  "version": "0.1.1",
  "description": "TypeScript type definitions for Home Assistant entities, services, and WebSocket API",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@glasshome/source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "tsc --noEmit"
  },
  "sideEffects": false,
  "keywords": [
    "home-assistant",
    "typescript",
    "types",
    "smart-home",
    "hass",
    "iot"
  ],
  "homepage": "https://github.com/glasshome/ha-types#readme",
  "bugs": {
    "url": "https://github.com/glasshome/ha-types/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/glasshome/ha-types.git"
  },
  "author": "GlassHome Labs",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "homeAssistant": {
    "version": "2025.12"
  },
  "devDependencies": {
    "tsdown": "^0.21.4",
    "typescript": "^5"
  }
}
